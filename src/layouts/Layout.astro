---
interface Props {
  title?: string;
}
const { title = "Ardora · Skincare Coreano en RD" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content="Todo para amar tu piel un poco más. Skincare coreano con envío gratis desde RD$5,000 en Santo Domingo." />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Josefin+Sans:wght@300;400;500;600;700&family=Dancing+Script:wght@500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-dvh bg-cream">
    <slot />
  </body>
</html>
